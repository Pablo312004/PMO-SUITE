PORT=3000
NODE_ENV=production

# ══════════════════════════════════════════════════════════════
# BANCO DE DADOS — Supabase Session Pooler
# Copie as credenciais em: Supabase → Settings → Database → Connection string
# ══════════════════════════════════════════════════════════════
DB_HOST=aws-0-XX-REGION.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.SEU_PROJECT_REF
DB_PASSWORD=SUA_SENHA_DO_BANCO

# ══════════════════════════════════════════════════════════════
# JWT — troque por strings longas e aleatórias em produção
# ══════════════════════════════════════════════════════════════
JWT_SECRET=troque_por_string_aleatoria_minimo_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_diferente

# ══════════════════════════════════════════════════════════════
# URL do Frontend
# ══════════════════════════════════════════════════════════════
FRONTEND_URL=https://seu-app.onrender.com

# ══════════════════════════════════════════════════════════════
# Supabase (para OAuth Google)
# Supabase → Settings → API
# ══════════════════════════════════════════════════════════════
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=SUA_ANON_KEY_PUBLICA

# ══════════════════════════════════════════════════════════════
# EMAIL (Resend) — https://resend.com
# ══════════════════════════════════════════════════════════════
RESEND_API_KEY=re_SUA_API_KEY
NOTIFY_EMAILS=email1@empresa.com,email2@empresa.com,email3@empresa.com
NOTIFY_FROM=PMO Suite <noreply@seudominio.com>
